rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Product Images ───────────────────────────────────────────────────────
    // Only the admin account can upload or delete product images.
    // Anyone can read (images are public for the storefront).
    match /products/{imageFile} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'admin@zahrah.com'
                   && request.resource.contentType.matches('image/.*')
                   && request.resource.size < 10 * 1024 * 1024; // Max 10 MB
    }

    // ─── Banner / Hero Images ─────────────────────────────────────────────────
    match /banners/{imageFile} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'admin@zahrah.com'
                   && request.resource.contentType.matches('image/.*')
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // ─── Catch-all ────────────────────────────────────────────────────────────
    // Any path not explicitly allowed above requires admin auth.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'admin@zahrah.com';
    }
  }
}
