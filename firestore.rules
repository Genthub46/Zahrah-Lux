rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Products: Public Read, Admin Write
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders: Admin Read/Update, Public Create
    match /orders/{orderId} {
      allow read, update, delete: if request.auth != null;
      allow create: if true;
    }

    // Restock Requests: Admin Read/Delete, Public Create
    match /restock_requests/{requestId} {
      allow read, delete: if request.auth != null;
      allow create: if true;
    }

    // View Logs: Public Create, Admin Read
    match /view_logs/{logId} {
      allow read: if request.auth != null;
      allow create: if true;
    }

    // Site Config / Footer Pages: Public Read, Admin Write
    match /siteConfig/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /footerPages/{pageId} {
       allow read: if true;
       allow write: if request.auth != null;
    }

    // Catch-all (Default): Public Read, Admin Write
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
