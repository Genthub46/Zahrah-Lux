rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check for Admin Email
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@zahrah.com';
    }

    // Products: Public Read, Admin Write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: Admin Read/Update, Public Create (logic handles order creation)
    match /orders/{orderId} {
      allow read, update, delete: if isAdmin();
      allow create: if true; // Public can create orders
    }

    // Restock Requests: Admin Read/Delete, Public Create
    match /restockRequests/{requestId} {
      allow read, delete: if isAdmin();
      allow create: if true;
    }

    // View Logs: Admin Read, Public Create
    match /viewLogs/{logId} {
      allow read: if isAdmin();
      allow create: if true;
    }

    // Reviews: Public Create, Public Read, Admin Moderate
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if true; // Authenticated or Guest reviews? Typically auth needed for credibility but let's allow true for now as per previous logic
      allow update, delete: if isAdmin();
    }

    // Site Config / Footer Pages: Public Read, Admin Write
    match /siteConfig/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /pages/{pageId} {
       allow read: if true;
       allow write: if isAdmin();
    }

    // User Data: Users can read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Catch-all (Default): Public Read, Admin Write
    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
