rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── Helper Functions ──────────────────────────────────────────────────────

    function getAdminRole() {
      return request.auth != null && 'email' in request.auth.token ? (
        request.auth.token.email.lower() == 'admin@zahrah.com' ? 'super_admin' : 
        (exists(/databases/$(database)/documents/staff_members/$(request.auth.token.email.lower())) ? 
          get(/databases/$(database)/documents/staff_members/$(request.auth.token.email.lower())).data.role : null)
      ) : null;
    }

    function isSuperAdmin() { return getAdminRole() == 'super_admin'; }
    function isManagerOrAbove() { return getAdminRole() in ['super_admin', 'manager']; }
    function isSupportOrAbove() { return getAdminRole() in ['super_admin', 'manager', 'support']; }
    function isViewerOrAbove() { return getAdminRole() in ['super_admin', 'manager', 'support', 'viewer']; }

    function isValidEmail(email) {
      return email is string && email.matches('.*@.*\\..*') && email.size() >= 5 && email.size() <= 254;
    }

    // ─── Staff Members ────────────────────────────────────────────────────────
    match /staff_members/{emailId} {
      allow read, write: if isSuperAdmin();
    }

    // ─── Products ─────────────────────────────────────────────────────────────
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isManagerOrAbove();
      allow update: if isManagerOrAbove();
    }

    // ─── Categories & Brands ─────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isManagerOrAbove();
    }
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isManagerOrAbove();
    }

    // ─── Orders ───────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isViewerOrAbove()
                  || (request.auth != null
                      && resource.data.customerEmail == request.auth.token.email.lower());
      allow update: if isSupportOrAbove();
      allow delete: if isManagerOrAbove();
      allow create: if isValidEmail(request.resource.data.customerEmail)
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && request.resource.data.total is number
                    && request.resource.data.total > 0
                    && request.resource.data.status == 'Pending'
                    && (!('paymentStatus' in request.resource.data) || request.resource.data.paymentStatus in ['Pending', 'Failed']) // 'Paid' blocked for clients
                    && (!('paymentMethod' in request.resource.data) || request.resource.data.paymentMethod in ['Paystack', 'COD'])
                    && (!('userId' in request.resource.data) || request.resource.data.userId == null || request.resource.data.userId == '' || (request.auth != null && request.resource.data.userId == request.auth.uid))
                    && request.resource.data.customerName is string && request.resource.data.customerName.size() >= 2
                    && request.resource.data.customerPhone is string && request.resource.data.customerPhone.size() >= 7
                    && request.resource.data.customerAddress is string && request.resource.data.customerAddress.size() >= 5;
    }

    // ─── Restock Requests ────────────────────────────────────────────────────
    match /restockRequests/{requestId} {
      allow read: if isViewerOrAbove();
      allow update: if isSupportOrAbove();
      allow delete: if isManagerOrAbove();
      allow create: if isValidEmail(request.resource.data.email);
    }

    // ─── View Logs ───────────────────────────────────────────────────────────
    match /viewLogs/{logId} {
      allow read: if isViewerOrAbove();
      allow create: if request.resource.data.productId is string
                    && request.resource.data.productId.size() > 0
                    && request.auth != null;
    }

    // ─── Admin Logs ──────────────────────────────────────────────────────────
    match /adminLogs/{logId} {
      allow read: if isViewerOrAbove();
      allow create: if isViewerOrAbove();
      allow update, delete: if isSuperAdmin();
    }

    // ─── Newsletter ──────────────────────────────────────────────────────────
    match /newsletter/{subId} {
      allow read, delete: if isManagerOrAbove();
      allow create: if isValidEmail(request.resource.data.email);
    }

    // ─── Reviews ─────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidEmail(request.resource.data.customerEmail)
                    && request.resource.data.rating is number
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.comment is string
                    && request.resource.data.comment.size() >= 5;
      allow update, delete: if isManagerOrAbove();
    }

    // ─── Site Config & Pages ─────────────────────────────────────────────────
    match /siteConfig/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    match /pages/{pageId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ─── User Data ───────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId || isViewerOrAbove();
      allow write: if request.auth != null && request.auth.uid == userId || isManagerOrAbove();
    }

    // ─── Abandoned Checkouts ─────────────────────────────────────────────────
    match /abandonedCheckouts/{sessionId} {
      allow read: if isViewerOrAbove() || (request.auth != null && request.auth.uid == resource.data.userId);
      allow delete: if isManagerOrAbove() || (request.auth != null && request.auth.uid == resource.data.userId);
      allow create, update: if isValidEmail(request.resource.data.email)
                            && request.resource.data.cart is list
                            && request.resource.data.cart.size() > 0
                            && request.resource.data.sessionId is string;
    }

    // ─── Global Fallback ───────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
